<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="light dark">
<title><%= typeof title !== 'undefined' ? title : 'htmlhost' %></title>
<script>
  (function() {
    var t = localStorage.getItem('theme');
    if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', t);
  })();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --font-sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
    --space-5: 24px; --space-6: 32px; --space-7: 48px; --space-8: 64px;
    --t: 120ms ease-out;
  }
  :root, [data-theme="light"] {
    --bg: #ffffff;
    --bg-elevated: #fafafa;
    --bg-hover: #f5f5f5;
    --bg-active: #ececec;
    --text: #0a0a0a;
    --text-muted: #6b6b6b;
    --text-subtle: #a0a0a0;
    --border: rgba(0, 0, 0, 0.08);
    --border-strong: rgba(0, 0, 0, 0.14);
    --accent: #0066ff;
    --accent-hover: #0052cc;
    --accent-text: #ffffff;
    --accent-soft: rgba(0, 102, 255, 0.08);
    --danger: #dc2626;
    --danger-soft: rgba(220, 38, 38, 0.08);
    --selection: rgba(0, 102, 255, 0.15);
    --code-bg: #f5f5f5;
  }
  [data-theme="dark"] {
    --bg: #0a0a0a;
    --bg-elevated: #141414;
    --bg-hover: #1c1c1c;
    --bg-active: #242424;
    --text: #fafafa;
    --text-muted: #a0a0a0;
    --text-subtle: #6b6b6b;
    --border: rgba(255, 255, 255, 0.08);
    --border-strong: rgba(255, 255, 255, 0.14);
    --accent: #4d8aff;
    --accent-hover: #6b9eff;
    --accent-text: #0a0a0a;
    --accent-soft: rgba(77, 138, 255, 0.12);
    --danger: #f87171;
    --danger-soft: rgba(248, 113, 113, 0.1);
    --selection: rgba(77, 138, 255, 0.3);
    --code-bg: #141414;
  }
  html, body { background: var(--bg); color: var(--text); }
  body {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.5;
    font-feature-settings: 'cv11', 'ss01';
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  ::selection { background: var(--selection); }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
  input, textarea, select { font: inherit; color: inherit; background: none; border: none; }
  code, pre, .mono { font-family: var(--font-mono); font-size: 0.875em; }
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  ::-webkit-scrollbar { width: 10px; height: 10px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); }
  ::-webkit-scrollbar-thumb:hover { background: var(--border-strong); }

  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2);
    height: 32px; padding: 0 var(--space-3);
    font-size: 13px; font-weight: 500; line-height: 1;
    background: transparent; color: var(--text);
    border: 1px solid var(--border);
    transition: background var(--t), border-color var(--t), color var(--t);
    white-space: nowrap;
  }
  .btn:hover { background: var(--bg-hover); border-color: var(--border-strong); }
  .btn:active { background: var(--bg-active); }
  .btn-primary { background: var(--accent); color: var(--accent-text); border-color: var(--accent); }
  .btn-primary:hover { background: var(--accent-hover); border-color: var(--accent-hover); }
  .btn-danger { color: var(--danger); border-color: var(--border); }
  .btn-danger:hover { background: var(--danger-soft); border-color: var(--danger); }
  .btn-ghost { border-color: transparent; }
  .btn-ghost:hover { background: var(--bg-hover); border-color: transparent; }
  .btn-sm { height: 26px; padding: 0 var(--space-2); font-size: 12px; }
  .btn-lg { height: 38px; padding: 0 var(--space-4); font-size: 14px; }
  .btn-block { width: 100%; }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; pointer-events: none; }

  .icon-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 32px; height: 32px;
    color: var(--text-muted);
    transition: background var(--t), color var(--t);
  }
  .icon-btn:hover { background: var(--bg-hover); color: var(--text); }
  .icon-btn svg { width: 16px; height: 16px; }

  .input, .textarea, .select {
    display: block; width: 100%;
    padding: var(--space-2) var(--space-3);
    font-size: 13px; line-height: 1.5;
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    transition: border-color var(--t), background var(--t);
  }
  .input:hover, .textarea:hover, .select:hover { border-color: var(--border-strong); }
  .input:focus, .textarea:focus, .select:focus { outline: none; border-color: var(--accent); }
  .textarea { font-family: var(--font-mono); resize: vertical; min-height: 80px; }
  .select { appearance: none; -webkit-appearance: none; padding-right: var(--space-7); background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%236b6b6b'><path d='M4 6l4 4 4-4'/></svg>"); background-repeat: no-repeat; background-position: right 12px center; background-size: 14px; }
  [data-theme="dark"] .select { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23a0a0a0'><path d='M4 6l4 4 4-4'/></svg>"); }

  .label {
    display: block; font-size: 12px; font-weight: 500; color: var(--text-muted);
    margin-bottom: var(--space-2); text-transform: uppercase; letter-spacing: 0.04em;
  }

  .section { padding: var(--space-7) 0; border-top: 1px solid var(--border); }
  .section:first-of-type { border-top: none; padding-top: var(--space-6); }
  .section-head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: var(--space-5);
  }
  .section-title {
    font-size: 11px; font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .section-count { font-size: 11px; color: var(--text-subtle); font-variant-numeric: tabular-nums; }

  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    display: none; align-items: center; justify-content: center;
    z-index: 100; padding: var(--space-4);
  }
  [data-theme="dark"] .modal-overlay { background: rgba(0, 0, 0, 0.7); }
  .modal-overlay.active { display: flex; }
  .modal {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    width: 100%; max-width: 480px;
    padding: var(--space-6);
  }
  .modal-title { font-size: 16px; font-weight: 600; margin-bottom: var(--space-2); }
  .modal-desc { font-size: 13px; color: var(--text-muted); margin-bottom: var(--space-5); }
  .modal-actions { display: flex; gap: var(--space-2); justify-content: flex-end; margin-top: var(--space-5); }

  .toast {
    position: fixed; bottom: var(--space-5); right: var(--space-5);
    background: var(--text); color: var(--bg);
    padding: var(--space-3) var(--space-4);
    font-size: 13px; font-weight: 500;
    border: 1px solid var(--border-strong);
    z-index: 200; pointer-events: none;
    opacity: 0; transform: translateY(8px);
    transition: opacity var(--t), transform var(--t);
  }
  .toast.show { opacity: 1; transform: translateY(0); }
</style>
