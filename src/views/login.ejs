<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'htmlhost — Login' }) %>
  <style>
    body { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: var(--space-4); }
    .theme-fab { position: fixed; top: var(--space-4); right: var(--space-4); }
    .login-card { width: 100%; max-width: 400px; }
    .brand { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-7); }
    .brand-mark { width: 18px; height: 18px; background: var(--text); }
    .brand-name { font-size: 16px; font-weight: 600; letter-spacing: -0.01em; }
    h1 { font-size: 24px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: var(--space-2); }
    .sub { color: var(--text-muted); font-size: 14px; margin-bottom: var(--space-6); }
    .form { display: flex; flex-direction: column; gap: var(--space-4); }
    .hint {
      margin-top: var(--space-6); padding-top: var(--space-5);
      border-top: 1px solid var(--border);
      font-size: 12px; color: var(--text-muted);
    }
    .hint code { color: var(--text); background: var(--code-bg); padding: 1px 5px; }
    .msg { font-size: 13px; padding: var(--space-2) var(--space-3); border: 1px solid var(--border); display: none; }
    .msg.show { display: block; }
    .msg.error { color: var(--danger); border-color: var(--danger); background: var(--danger-soft); }
    .msg.info { color: var(--text-muted); }
  </style>
</head>
<body>
  <button class="icon-btn theme-fab" onclick="toggleTheme()" aria-label="Toggle theme" data-theme-icon></button>

  <div class="login-card">
    <div class="brand">
      <div class="brand-mark"></div>
      <div class="brand-name">htmlhost</div>
    </div>

    <h1>Sign in</h1>
    <p class="sub">Enter your 12-word mnemonic to unlock.</p>

    <form id="loginForm" class="form" autocomplete="off">
      <div>
        <label class="label" for="mnemonic">Mnemonic Phrase</label>
        <textarea id="mnemonic" class="textarea" rows="3" placeholder="word1 word2 word3 ..." spellcheck="false" required></textarea>
      </div>
      <div class="msg info" id="deriving">Deriving key…</div>
      <div class="msg error" id="error"></div>
      <button type="submit" class="btn btn-primary btn-lg btn-block" id="submitBtn">Unlock</button>
    </form>

    <div class="hint">
      No account? Create one with the CLI: <code>node cli/paste.js create-user</code>
    </div>
  </div>

  <%- include('partials/theme') %>

  <script>
    const cryptoParams = <%- JSON.stringify(cryptoParams).replace(/</g, '\\u003c') %>;
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const mnemonic = document.getElementById('mnemonic').value.trim();
      const errorEl = document.getElementById('error');
      const derivingEl = document.getElementById('deriving');
      const btn = document.getElementById('submitBtn');
      errorEl.classList.remove('show');
      derivingEl.classList.add('show');
      btn.disabled = true;
      try {
        const normalized = mnemonic.toLowerCase().trim().split(/\s+/).join(' ');
        const salt = new TextEncoder().encode(cryptoParams.saltPrefix + normalized);
        const keyMaterial = await crypto.subtle.importKey(
          'raw', new TextEncoder().encode(normalized), 'PBKDF2', false, ['deriveBits']
        );
        const derivedBits = await crypto.subtle.deriveBits(
          { name: 'PBKDF2', salt, iterations: cryptoParams.iterations, hash: 'SHA-256' },
          keyMaterial, cryptoParams.keyLength * 8
        );
        const apiKey = 'ps_' + Array.from(new Uint8Array(derivedBits)).slice(0, 16).map(b => b.toString(16).padStart(2, '0')).join('');
        const res = await fetch('/login', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mnemonic })
        });
        const data = await res.json();
        if (res.ok && data.success) {
          window.location.href = '/';
        } else {
          errorEl.textContent = data.error || 'Login failed';
          errorEl.classList.add('show');
        }
      } catch (err) {
        errorEl.textContent = 'Derivation failed: ' + err.message;
        errorEl.classList.add('show');
      } finally {
        derivingEl.classList.remove('show');
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
