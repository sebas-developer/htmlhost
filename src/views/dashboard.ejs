<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'htmlhost — Dashboard' }) %>
  <style>
    .container { max-width: 1100px; margin: 0 auto; padding: 0 var(--space-5); }

    .topbar {
      position: sticky; top: 0; z-index: 50;
      display: flex; align-items: center; gap: var(--space-3);
      height: 56px; padding: 0 var(--space-5);
      background: var(--bg);
      border-bottom: 1px solid var(--border);
    }
    .topbar .container { display: flex; align-items: center; gap: var(--space-3); padding: 0; }
    .brand { display: flex; align-items: center; gap: var(--space-2); margin-right: auto; }
    .brand-mark { width: 14px; height: 14px; background: var(--text); }
    .brand-name { font-size: 14px; font-weight: 600; letter-spacing: -0.01em; }
    .actions { display: flex; align-items: center; gap: var(--space-2); }

    main { padding-bottom: var(--space-8); }

    .pastes-grid {
      display: grid; gap: var(--space-3);
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    }
    .paste {
      display: flex; flex-direction: column;
      background: var(--bg);
      border: 1px solid var(--border);
      transition: border-color var(--t), background var(--t);
    }
    .paste:hover { border-color: var(--border-strong); }
    .paste-preview {
      aspect-ratio: 16 / 10;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--border);
      position: relative; overflow: hidden;
    }
    .paste-preview iframe {
      position: absolute; top: 0; left: 0;
      width: 200%; height: 200%;
      transform: scale(0.5);
      transform-origin: top left;
      border: none; pointer-events: none;
      background: #fff;
    }
    .paste-body { padding: var(--space-3) var(--space-4); display: flex; flex-direction: column; gap: var(--space-3); }
    .paste-id {
      font-family: var(--font-mono);
      font-size: 12px; font-weight: 500;
      color: var(--text);
      word-break: break-all;
    }
    .paste-meta { display: flex; align-items: center; gap: var(--space-2); font-size: 12px; color: var(--text-muted); }
    .pill {
      display: inline-flex; align-items: center; gap: var(--space-1);
      padding: 2px 6px;
      font-size: 10px; font-weight: 500;
      color: var(--text-muted);
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      letter-spacing: 0.02em;
    }
    .pill-danger { color: var(--danger); border-color: var(--danger); background: var(--danger-soft); }
    .dot { width: 6px; height: 6px; background: currentColor; }
    .paste-actions { display: flex; gap: var(--space-2); }

    .empty {
      padding: var(--space-7) var(--space-5);
      text-align: center;
      border: 1px dashed var(--border);
      color: var(--text-muted);
      font-size: 13px;
    }
    .empty strong { color: var(--text); font-weight: 600; display: block; margin-bottom: var(--space-1); }

    .keys-list { border: 1px solid var(--border); }
    .keys-list .row {
      display: grid; grid-template-columns: 1fr auto auto;
      align-items: center; gap: var(--space-4);
      padding: var(--space-3) var(--space-4);
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }
    .keys-list .row:last-child { border-bottom: none; }
    .keys-list .row.head {
      background: var(--bg-elevated);
      font-size: 11px; font-weight: 600; color: var(--text-muted);
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .keys-list .label-cell { font-weight: 500; }
    .keys-list .label-cell .sub { color: var(--text-muted); font-weight: 400; font-size: 12px; }
    .keys-list .date { color: var(--text-muted); font-variant-numeric: tabular-nums; font-size: 12px; }

    .docs { display: flex; flex-direction: column; gap: var(--space-6); }
    .docs h3 {
      font-size: 14px; font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: var(--space-2);
    }
    .docs p { font-size: 13px; color: var(--text-muted); }
    .docs p code { background: var(--code-bg); padding: 1px 5px; color: var(--text); }
    .docs pre {
      background: var(--code-bg);
      border: 1px solid var(--border);
      padding: var(--space-4);
      overflow-x: auto;
      font-size: 12px; line-height: 1.6;
      color: var(--text);
    }
    .docs pre code { color: inherit; }
    .docs .endpoint { color: var(--text-muted); }
    .docs .method { display: inline-block; min-width: 56px; font-weight: 600; color: var(--accent); }

    .upload-form { display: flex; flex-direction: column; gap: var(--space-4); }
    .upload-form .row { display: grid; grid-template-columns: 80px 1fr; gap: var(--space-3); align-items: start; }
    .upload-form .row > .label { margin-bottom: 0; padding-top: 8px; }

    .dropzone {
      position: relative;
      min-height: 140px;
      display: flex; align-items: center; justify-content: center;
      background: var(--bg);
      border: 1px dashed var(--border-strong);
      cursor: pointer;
      transition: border-color var(--t), background var(--t);
    }
    .dropzone:hover { border-color: var(--accent); background: var(--accent-soft); }
    .dropzone.dragover { border-style: solid; border-color: var(--accent); background: var(--accent-soft); }
    .dropzone.error { border-color: var(--danger); background: var(--danger-soft); }
    .dropzone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
    .dz-empty, .dz-filled {
      display: flex; flex-direction: column; align-items: center; gap: var(--space-2);
      padding: var(--space-5); text-align: center;
      pointer-events: none;
    }
    .dz-filled { display: none; flex-direction: row; align-items: center; gap: var(--space-3); text-align: left; padding: var(--space-3) var(--space-4); width: 100%; }
    .dropzone.has-file .dz-empty { display: none; }
    .dropzone.has-file .dz-filled { display: flex; }
    .dropzone.has-file input[type="file"] { display: none; }
    .dz-icon { width: 24px; height: 24px; color: var(--text-muted); }
    .dz-title { font-size: 13px; font-weight: 500; color: var(--text); }
    .dz-sub { font-size: 12px; color: var(--text-muted); }
    .dz-sub .link { color: var(--accent); font-weight: 500; }
    .dz-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .dz-name { font-family: var(--font-mono); font-size: 12px; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .dz-size { font-size: 11px; color: var(--text-muted); font-variant-numeric: tabular-nums; }
    .dz-clear { pointer-events: auto; font-size: 12px; color: var(--danger); padding: var(--space-1) var(--space-2); }
    .dz-clear:hover { background: var(--danger-soft); }

    .paste-toggle { border-top: 1px solid var(--border); padding-top: var(--space-3); }
    .paste-toggle summary {
      list-style: none; cursor: pointer;
      font-size: 12px; color: var(--text-muted);
      user-select: none;
    }
    .paste-toggle summary::-webkit-details-marker { display: none; }
    .paste-toggle summary::before { content: '+ '; color: var(--text-subtle); font-family: var(--font-mono); }
    .paste-toggle[open] summary::before { content: '− '; }
    .paste-toggle summary:hover { color: var(--text); }
    .paste-toggle textarea { margin-top: var(--space-3); min-height: 140px; }

    .cred-warning {
      display: flex; gap: var(--space-3);
      padding: var(--space-3);
      background: var(--danger-soft);
      border: 1px solid var(--danger);
      font-size: 12px; color: var(--danger);
      margin-bottom: var(--space-4);
    }
    .cred-warning svg { flex-shrink: 0; width: 16px; height: 16px; }

    @media (max-width: 640px) {
      .topbar { padding: 0 var(--space-3); }
      .container { padding: 0 var(--space-3); }
      .actions .btn span { display: none; }
      .keys-list .row { grid-template-columns: 1fr auto; }
      .keys-list .date { display: none; }
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="container">
      <a href="/" class="brand">
        <div class="brand-mark"></div>
        <div class="brand-name">htmlhost</div>
      </a>
      <div class="actions">
        <button class="btn btn-sm" onclick="showUploadModal()">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 3v10M3 8h10"/></svg>
          <span>Upload</span>
        </button>
        <button class="btn btn-sm" onclick="showKeyModal()">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 3v10M3 8h10"/></svg>
          <span>New Key</span>
        </button>
        <button class="icon-btn" onclick="toggleTheme()" aria-label="Toggle theme" data-theme-icon></button>
        <form action="/logout" method="POST" style="margin:0">
          <button type="submit" class="btn btn-sm btn-ghost" title="Sign out">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 3H3v10h3M10 5l3 3-3 3M6 8h7"/></svg>
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="container">
    <main>
      <section class="section">
        <div class="section-head">
          <div class="section-title">Pastes</div>
          <div class="section-count"><%= pastes.length %></div>
        </div>
        <% if (pastes.length === 0) { %>
          <div class="empty">
            <strong>No pastes yet</strong>
            Upload your first HTML file to get started.
          </div>
        <% } else { %>
          <div class="pastes-grid">
            <% pastes.forEach(function(p) { %>
              <div class="paste" id="paste-<%= p.id %>">
                <div class="paste-preview">
                  <iframe src="/p/<%= p.id %>" sandbox="allow-same-origin" loading="lazy" tabindex="-1"></iframe>
                </div>
                <div class="paste-body">
                  <div class="paste-id">/p/<%= p.id %></div>
                  <div class="paste-meta">
                    <span class="pill <%= p.expired ? 'pill-danger' : '' %>">
                      <span class="dot"></span>
                      <%= p.ttl %><% if (p.expired) { %> &middot; expired<% } %>
                    </span>
                  </div>
                  <div class="paste-actions">
                    <button class="btn btn-sm" onclick="copyUrl('<%= p.id %>')">Copy URL</button>
                    <button class="btn btn-sm btn-danger" onclick="deletePaste('<%= p.id %>')">Delete</button>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </section>

      <section class="section">
        <div class="section-head">
          <div class="section-title">API Keys</div>
          <div class="section-count"><%= keys.length %></div>
        </div>
        <% if (keys.length === 0) { %>
          <div class="empty">
            <strong>No API keys</strong>
            Create one to use with the CLI.
          </div>
        <% } else { %>
          <div class="keys-list">
            <div class="row head">
              <div>Label</div>
              <div>Created</div>
              <div></div>
            </div>
            <% keys.forEach(function(k) { %>
              <div class="row">
                <div class="label-cell"><%= k.label || '(unnamed)' %></div>
                <div class="date"><%= new Date(k.created_at).toLocaleDateString() %></div>
                <div><button class="btn btn-sm btn-danger" onclick="deleteKey('<%= k.id %>')">Delete</button></div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </section>

      <section class="section">
        <div class="section-head">
          <div class="section-title">Setup &amp; API</div>
        </div>
        <div class="docs">
          <div>
            <h3>CLI Installation</h3>
            <p>Run the CLI directly or install it globally.</p>
            <pre><code>npm install -g paste-cli
# or run directly:
node cli/paste.js</code></pre>
          </div>

          <div>
            <h3>Upload HTML</h3>
            <pre><code>PASTE_API_KEY=ps_... node cli/paste.js upload index.html
PASTE_API_KEY=ps_... node cli/paste.js upload index.html --ttl 7d</code></pre>
          </div>

          <div>
            <h3>List Pastes</h3>
            <pre><code>PASTE_API_KEY=ps_... node cli/paste.js list</code></pre>
          </div>

          <div>
            <h3>API Reference</h3>
            <p>Base URL: <code><%= baseUrl %></code></p>
            <pre><code><span class="method">POST</span>   <span class="endpoint">/api/pastes</span>
  Authorization: Bearer ps_...
  X-TTL: 3d (optional: 1h, 3h, 1d, 3d, 7d, 30d, indefinite)
  Body: raw HTML

<span class="method">GET</span>    <span class="endpoint">/api/pastes</span>
  Authorization: Bearer ps_...

<span class="method">GET</span>    <span class="endpoint">/api/pastes/:id</span>
  Authorization: Bearer ps_...

<span class="method">DELETE</span> <span class="endpoint">/api/pastes/:id</span>
  Authorization: Bearer ps_...</code></pre>
          </div>

          <div>
            <h3>opencode Skill</h3>
            <p>Copy <code>skills/paste-service.md</code> to <code>~/.config/opencode/skills/</code> to enable it in the opencode CLI.</p>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div class="modal-overlay" id="uploadModal">
    <div class="modal">
      <div class="modal-title">Upload HTML</div>
      <div class="modal-desc">Drop a file, browse, or paste HTML directly.</div>
      <form class="upload-form" onsubmit="event.preventDefault(); doUpload();">
        <div class="row">
          <label class="label" for="uploadTtl">TTL</label>
          <select id="uploadTtl" class="select">
            <option value="1h">1 hour</option>
            <option value="3h">3 hours</option>
            <option value="1d">1 day</option>
            <option value="3d" selected>3 days</option>
            <option value="7d">7 days</option>
            <option value="30d">30 days</option>
            <option value="indefinite">Indefinite</option>
          </select>
        </div>
        <div class="row">
          <label class="label">File</label>
          <div class="dropzone" id="dropzone">
            <input type="file" id="fileInput" accept=".html,.htm,.txt,text/html,text/plain">
            <div class="dz-empty">
              <svg class="dz-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 16V4M12 4l-4 4M12 4l4 4"/>
                <path d="M4 14v4a2 2 0 002 2h12a2 2 0 002-2v-4"/>
              </svg>
              <div class="dz-title">Drop HTML file</div>
              <div class="dz-sub">or <span class="link">click to browse</span></div>
            </div>
            <div class="dz-filled">
              <svg class="dz-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <path d="M14 2v6h6"/>
              </svg>
              <div class="dz-info">
                <div class="dz-name" id="dzName"></div>
                <div class="dz-size" id="dzSize"></div>
              </div>
              <button type="button" class="dz-clear" id="dzClear">Remove</button>
            </div>
          </div>
        </div>
        <details class="paste-toggle">
          <summary>paste HTML directly</summary>
          <textarea id="uploadHtml" placeholder="<html>...</html>"></textarea>
        </details>
        <div class="modal-actions">
          <button type="button" class="btn" onclick="hideModal('uploadModal')">Cancel</button>
          <button type="submit" class="btn btn-primary" id="uploadBtn">Upload</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="keyModal">
    <div class="modal">
      <div class="modal-title">Create API Key</div>
      <div class="modal-desc">Used to authenticate CLI uploads and API requests.</div>
      <form onsubmit="event.preventDefault(); doCreateKey();">
        <label class="label" for="keyLabel">Label</label>
        <input id="keyLabel" class="input" type="text" placeholder="e.g. laptop, work" />
        <div class="modal-actions">
          <button type="button" class="btn" onclick="hideModal('keyModal')">Cancel</button>
          <button type="submit" class="btn btn-primary">Create</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="keyResultModal">
    <div class="modal">
      <div class="modal-title">Save your credentials</div>
      <div class="cred-warning">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6.5"/><path d="M8 5v3.5M8 11h.01"/></svg>
        <div>These will not be shown again. Save them somewhere safe now.</div>
      </div>
      <label class="label" for="resultMnemonic">Mnemonic Phrase</label>
      <textarea id="resultMnemonic" class="textarea" readonly rows="2" style="min-height:auto"></textarea>
      <label class="label" for="resultApiKey" style="margin-top:var(--space-3)">API Key</label>
      <input id="resultApiKey" class="input mono" readonly />
      <div class="modal-actions">
        <button type="button" class="btn" onclick="hideModal('keyResultModal')">Close</button>
        <button type="button" class="btn btn-primary" onclick="copyCreds()">Copy All</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <%- include('partials/theme') %>

  <script>
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      clearTimeout(t._timer);
      t._timer = setTimeout(() => t.classList.remove('show'), 2000);
    }

    function hideModal(id) { document.getElementById(id).classList.remove('active'); }
    function showUploadModal() {
      resetUploadModal();
      document.getElementById('uploadModal').classList.add('active');
    }
    function showKeyModal() {
      document.getElementById('keyLabel').value = '';
      document.getElementById('keyModal').classList.add('active');
      setTimeout(() => document.getElementById('keyLabel').focus(), 50);
    }

    document.querySelectorAll('.modal-overlay').forEach(o => {
      o.addEventListener('click', e => { if (e.target === o) o.classList.remove('active'); });
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') document.querySelectorAll('.modal-overlay.active').forEach(m => m.classList.remove('active'));
    });

    const MAX_BYTES = 1024 * 1024;
    let uploadFile = null;
    function formatBytes(b) {
      if (b < 1024) return b + ' B';
      if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
      return (b / 1024 / 1024).toFixed(2) + ' MB';
    }
    function resetUploadModal() {
      uploadFile = null;
      const dz = document.getElementById('dropzone');
      dz.classList.remove('has-file', 'error', 'dragover');
      document.getElementById('uploadHtml').value = '';
      document.getElementById('fileInput').value = '';
    }
    async function setUploadFile(file) {
      const dz = document.getElementById('dropzone');
      dz.classList.remove('error', 'dragover');
      if (!file) { resetUploadModal(); return; }
      if (file.size > MAX_BYTES) {
        dz.classList.add('error');
        showToast('File too large (max 1 MB)');
        return;
      }
      if (file.size === 0) {
        dz.classList.add('error');
        showToast('File is empty');
        return;
      }
      try {
        const text = await file.text();
        uploadFile = { name: file.name, size: file.size, text };
        document.getElementById('dzName').textContent = file.name;
        document.getElementById('dzSize').textContent = formatBytes(file.size);
        dz.classList.add('has-file');
      } catch (err) {
        dz.classList.add('error');
        showToast('Could not read file: ' + err.message);
      }
    }
    (function setupDropzone() {
      const dz = document.getElementById('dropzone');
      const input = document.getElementById('fileInput');
      let dragDepth = 0;
      dz.addEventListener('dragenter', e => {
        e.preventDefault();
        dragDepth++;
        if (e.dataTransfer.types.includes('Files')) dz.classList.add('dragover');
      });
      dz.addEventListener('dragover', e => { e.preventDefault(); e.dataTransfer.dropEffect = 'copy'; });
      dz.addEventListener('dragleave', () => { if (--dragDepth <= 0) { dragDepth = 0; dz.classList.remove('dragover'); } });
      dz.addEventListener('drop', e => {
        e.preventDefault();
        dragDepth = 0;
        dz.classList.remove('dragover');
        const f = e.dataTransfer.files[0];
        if (f) setUploadFile(f);
      });
      input.addEventListener('change', e => { const f = e.target.files[0]; if (f) setUploadFile(f); });
      document.getElementById('dzClear').addEventListener('click', e => { e.stopPropagation(); resetUploadModal(); });
    })();

    async function doUpload() {
      const ttl = document.getElementById('uploadTtl').value;
      const textarea = document.getElementById('uploadHtml').value;
      const html = uploadFile ? uploadFile.text : textarea;
      const btn = document.getElementById('uploadBtn');
      if (!html || !html.trim()) { showToast('Pick a file or paste HTML'); return; }
      btn.disabled = true;
      try {
        const res = await fetch('/api/pastes', {
          method: 'POST',
          headers: { 'Content-Type': 'text/html', 'X-TTL': ttl },
          body: html
        });
        const data = await res.json();
        if (res.ok) {
          hideModal('uploadModal');
          showToast('Uploaded: ' + data.url);
          setTimeout(() => location.reload(), 400);
        } else {
          showToast('Error: ' + (data.error || 'upload failed'));
        }
      } finally {
        btn.disabled = false;
      }
    }

    async function deletePaste(id) {
      if (!confirm('Delete this paste?')) return;
      await fetch('/api/pastes/' + id, { method: 'DELETE' });
      document.getElementById('paste-' + id)?.remove();
      showToast('Deleted');
    }

    async function doCreateKey() {
      const label = document.getElementById('keyLabel').value;
      const res = await fetch('/api/keys', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ label })
      });
      const data = await res.json();
      if (res.ok) {
        hideModal('keyModal');
        document.getElementById('resultMnemonic').value = data.mnemonic;
        document.getElementById('resultApiKey').value = data.apiKey;
        document.getElementById('keyResultModal').classList.add('active');
      } else {
        showToast('Error: ' + (data.error || 'create failed'));
      }
    }

    async function deleteKey(id) {
      if (!confirm('Delete this key? All associated pastes will be deleted too.')) return;
      await fetch('/api/keys/' + id, { method: 'DELETE' });
      showToast('Key deleted');
      setTimeout(() => location.reload(), 400);
    }

    function copyUrl(id) {
      navigator.clipboard.writeText(window.location.origin + '/p/' + id);
      showToast('URL copied');
    }

    function copyCreds() {
      const m = document.getElementById('resultMnemonic').value;
      const k = document.getElementById('resultApiKey').value;
      navigator.clipboard.writeText('Mnemonic: ' + m + '\nAPI Key: ' + k);
      showToast('Copied to clipboard');
    }
  </script>
</body>
</html>
