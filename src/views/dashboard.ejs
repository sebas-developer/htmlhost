<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>htmlhost — Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'SF Mono', 'Fira Code', monospace;
      background: #0a0a0a;
      color: #e0e0e0;
      padding: 2rem;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #222;
    }
    h1 { font-size: 1.5rem; color: #fff; }
    .header-actions { display: flex; gap: 1rem; align-items: center; }
    .btn {
      padding: 0.5rem 1rem;
      background: #fff;
      color: #000;
      border: none;
      border-radius: 4px;
      font-family: inherit;
      font-size: 0.85rem;
      cursor: pointer;
      font-weight: 600;
    }
    .btn:hover { background: #ddd; }
    .btn-danger { background: #f44; color: #fff; }
    .btn-danger:hover { background: #d33; }
    .btn-sm { padding: 0.3rem 0.6rem; font-size: 0.75rem; }
    .section { margin-bottom: 2rem; }
    .section-title {
      font-size: 1rem;
      color: #888;
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }
    .card {
      background: #111;
      border: 1px solid #222;
      border-radius: 6px;
      overflow: hidden;
    }
    .card-preview {
      height: 140px;
      background: #0d0d0d;
      border-bottom: 1px solid #222;
      position: relative;
    }
    .card-preview iframe {
      width: 200%;
      height: 200%;
      transform: scale(0.5);
      transform-origin: top left;
      border: none;
      pointer-events: none;
    }
    .card-info {
      padding: 0.75rem;
    }
    .card-id {
      font-size: 0.85rem;
      color: #fff;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }
    .card-meta {
      font-size: 0.75rem;
      color: #666;
      margin-bottom: 0.5rem;
    }
    .card-expired { color: #f44; }
    .card-actions { display: flex; gap: 0.5rem; }
    .empty {
      color: #444;
      font-size: 0.9rem;
      padding: 2rem;
      text-align: center;
    }
    .keys-table {
      width: 100%;
      border-collapse: collapse;
    }
    .keys-table th, .keys-table td {
      padding: 0.75rem;
      text-align: left;
      border-bottom: 1px solid #222;
      font-size: 0.85rem;
    }
    .keys-table th { color: #666; font-weight: normal; text-transform: uppercase; letter-spacing: 0.05em; }
    .docs {
      background: #111;
      border: 1px solid #222;
      border-radius: 6px;
      padding: 1.5rem;
      font-size: 0.85rem;
      line-height: 1.6;
    }
    .docs h3 { color: #fff; margin-bottom: 0.75rem; }
    .docs code {
      background: #1a1a1a;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      color: #aaa;
      font-size: 0.8rem;
    }
    .docs pre {
      background: #0d0d0d;
      border: 1px solid #222;
      border-radius: 4px;
      padding: 1rem;
      overflow-x: auto;
      margin: 0.75rem 0;
    }
    .docs pre code { background: none; padding: 0; color: #ccc; }
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.8);
      justify-content: center;
      align-items: center;
      z-index: 100;
    }
    .modal-overlay.active { display: flex; }
    .modal {
      background: #111;
      border: 1px solid #222;
      border-radius: 8px;
      padding: 2rem;
      width: 500px;
      max-width: 90vw;
    }
    .modal h2 { margin-bottom: 1rem; font-size: 1.1rem; }
    .modal textarea, .modal input {
      width: 100%;
      background: #0d0d0d;
      border: 1px solid #333;
      border-radius: 4px;
      color: #fff;
      font-family: inherit;
      font-size: 0.85rem;
      padding: 0.5rem;
      margin-bottom: 0.75rem;
    }
    .modal .btn-row { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem; }
    .modal .btn-secondary { background: #333; color: #fff; }
    .modal .btn-secondary:hover { background: #444; }
    .toast {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 6px;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      color: #fff;
      display: none;
      z-index: 200;
    }
    .toast.show { display: block; }
  </style>
</head>
<body>
  <div class="header">
    <h1>htmlhost</h1>
    <div class="header-actions">
      <button class="btn" onclick="showUploadModal()">+ Upload</button>
      <button class="btn" onclick="showKeyModal()">+ New Key</button>
      <form action="/logout" method="POST" style="margin:0">
        <button type="submit" class="btn btn-secondary">Logout</button>
      </form>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Your Pastes (<%= pastes.length %>)</div>
    <% if (pastes.length === 0) { %>
      <div class="empty">No pastes yet. Upload some HTML!</div>
    <% } else { %>
      <div class="grid">
        <% pastes.forEach(function(p) { %>
          <div class="card" id="paste-<%= p.id %>">
            <div class="card-preview">
              <iframe src="/p/<%= p.id %>" sandbox="allow-same-origin" loading="lazy"></iframe>
            </div>
            <div class="card-info">
              <div class="card-id">/p/<%= p.id %></div>
              <div class="card-meta <%= p.expired ? 'card-expired' : '' %>">
                <%= p.ttl %> <% if (p.expired) { %> (expired) <% } %>
              </div>
              <div class="card-actions">
                <button class="btn btn-sm" onclick="copyUrl('<%= p.id %>')">Copy URL</button>
                <button class="btn btn-sm btn-danger" onclick="deletePaste('<%= p.id %>')">Delete</button>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <div class="section">
    <div class="section-title">API Keys</div>
    <table class="keys-table">
      <thead>
        <tr><th>Label</th><th>Created</th><th></th></tr>
      </thead>
      <tbody>
        <% keys.forEach(function(k) { %>
          <tr>
            <td><%= k.label || '(unnamed)' %></td>
            <td><%= new Date(k.created_at).toLocaleDateString() %></td>
            <td><button class="btn btn-sm btn-danger" onclick="deleteKey('<%= k.id %>')">Delete</button></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Setup & API</div>
    <div class="docs">
      <h3>CLI Installation</h3>
      <pre><code>npm install -g paste-cli
# or run directly:
node cli/paste.js</code></pre>

      <h3>Upload HTML</h3>
      <pre><code>PASTE_API_KEY=ps_... node cli/paste.js upload index.html
PASTE_API_KEY=ps_... node cli/paste.js upload index.html --ttl 7d</code></pre>

      <h3>List Pastes</h3>
      <pre><code>PASTE_API_KEY=ps_... node cli/paste.js list</code></pre>

      <h3>API Reference</h3>
      <p>Base URL: <code><%= baseUrl %></code></p>
      <pre><code># Upload
POST /api/pastes
Authorization: Bearer ps_...
X-TTL: 3d (optional: 1h, 3h, 1d, 3d, 7d, 30d, indefinite)
Body: raw HTML

# List
GET /api/pastes
Authorization: Bearer ps_...

# Get
GET /api/pastes/:id
Authorization: Bearer ps_...

# Delete
DELETE /api/pastes/:id
Authorization: Bearer ps_...</code></pre>

      <h3>opencode Skill</h3>
      <p>Copy <code>skills/paste-service.md</code> to your <code>~/.config/opencode/skills/</code> directory.</p>
    </div>
  </div>

  <!-- Upload Modal -->
  <div class="modal-overlay" id="uploadModal">
    <div class="modal">
      <h2>Upload HTML</h2>
      <select id="uploadTtl" style="width:100%;background:#0d0d0d;border:1px solid #333;border-radius:4px;color:#fff;font-family:inherit;font-size:0.85rem;padding:0.5rem;margin-bottom:0.75rem">
        <option value="1h">1 hour</option>
        <option value="3h">3 hours</option>
        <option value="1d">1 day</option>
        <option value="3d" selected>3 days (default)</option>
        <option value="7d">7 days</option>
        <option value="30d">30 days</option>
        <option value="indefinite">Indefinite</option>
      </select>
      <textarea id="uploadHtml" rows="10" placeholder="Paste your HTML here..."></textarea>
      <div class="btn-row">
        <button class="btn btn-secondary" onclick="hideModal('uploadModal')">Cancel</button>
        <button class="btn" id="uploadBtn" onclick="doUpload()">Upload</button>
      </div>
    </div>
  </div>

  <!-- Key Modal -->
  <div class="modal-overlay" id="keyModal">
    <div class="modal">
      <h2>Create API Key</h2>
      <input id="keyLabel" type="text" placeholder="Label (optional)" />
      <div class="btn-row">
        <button class="btn btn-secondary" onclick="hideModal('keyModal')">Cancel</button>
        <button class="btn" onclick="doCreateKey()">Create</button>
      </div>
    </div>
  </div>

  <!-- Key Result Modal -->
  <div class="modal-overlay" id="keyResultModal">
    <div class="modal">
      <h2>Save Your Credentials</h2>
      <p style="color:#f44;margin-bottom:1rem;font-size:0.85rem">These will NOT be shown again. Save them now.</p>
      <label style="color:#888;font-size:0.85rem">Mnemonic Phrase</label>
      <textarea id="resultMnemonic" readonly rows="3" style="margin-bottom:1rem"></textarea>
      <label style="color:#888;font-size:0.85rem">API Key</label>
      <input id="resultApiKey" readonly />
      <div class="btn-row">
        <button class="btn" onclick="copyCreds()">Copy All</button>
        <button class="btn btn-secondary" onclick="hideModal('keyResultModal')">Close</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2000);
    }

    function hideModal(id) {
      document.getElementById(id).classList.remove('active');
    }

    function showUploadModal() {
      document.getElementById('uploadModal').classList.add('active');
    }

    function showKeyModal() {
      document.getElementById('keyModal').classList.add('active');
    }

    async function doUpload() {
      const html = document.getElementById('uploadHtml').value;
      const ttl = document.getElementById('uploadTtl').value;
      const btn = document.getElementById('uploadBtn');
      if (!html.trim()) return;

      btn.disabled = true;
      try {
        const res = await fetch('/api/pastes', {
          method: 'POST',
          headers: { 'Content-Type': 'text/html', 'X-TTL': ttl },
          body: html
        });
        const data = await res.json();
        if (res.ok) {
          hideModal('uploadModal');
          document.getElementById('uploadHtml').value = '';
          showToast('Uploaded! ' + data.url);
          setTimeout(() => location.reload(), 500);
        } else {
          showToast('Error: ' + data.error);
        }
      } finally {
        btn.disabled = false;
      }
    }

    async function deletePaste(id) {
      if (!confirm('Delete this paste?')) return;
      await fetch('/api/pastes/' + id, { method: 'DELETE' });
      document.getElementById('paste-' + id)?.remove();
      showToast('Deleted');
    }

    async function doCreateKey() {
      const label = document.getElementById('keyLabel').value;
      const res = await fetch('/api/keys', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ label })
      });
      const data = await res.json();
      if (res.ok) {
        hideModal('keyModal');
        document.getElementById('resultMnemonic').value = data.mnemonic;
        document.getElementById('resultApiKey').value = data.apiKey;
        document.getElementById('keyResultModal').classList.add('active');
      } else {
        showToast('Error: ' + data.error);
      }
    }

    async function deleteKey(id) {
      if (!confirm('Delete this key? All associated pastes will be deleted too.')) return;
      await fetch('/api/keys/' + id, { method: 'DELETE' });
      showToast('Key deleted');
      setTimeout(() => location.reload(), 500);
    }

    function copyUrl(id) {
      const url = window.location.origin + '/p/' + id;
      navigator.clipboard.writeText(url);
      showToast('URL copied!');
    }

    function copyCreds() {
      const m = document.getElementById('resultMnemonic').value;
      const k = document.getElementById('resultApiKey').value;
      navigator.clipboard.writeText('Mnemonic: ' + m + '\nAPI Key: ' + k);
      showToast('Copied!');
    }
  </script>
</body>
</html>
