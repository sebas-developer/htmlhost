<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'htmlhost — Password' }) %>
  <style>
    body { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: var(--space-4); }
    .theme-fab { position: fixed; top: var(--space-4); right: var(--space-4); }
    .pwd-card { width: 100%; max-width: 400px; }
    .brand { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-7); }
    .brand-mark { width: 18px; height: 18px; background: var(--text); }
    .brand-name { font-size: 16px; font-weight: 600; letter-spacing: -0.01em; }

    .pwd-icon {
      display: inline-flex; align-items: center; justify-content: center;
      width: 44px; height: 44px;
      background: var(--accent-soft);
      color: var(--accent);
      margin-bottom: var(--space-5);
    }
    .pwd-icon svg { width: 20px; height: 20px; }

    h1 { font-size: 24px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: var(--space-2); }
    .sub { color: var(--text-muted); font-size: 14px; margin-bottom: var(--space-6); }
    .sub .paste-id {
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--text);
    }

    .form { display: flex; flex-direction: column; gap: var(--space-4); }

    .input-wrap { position: relative; }
    .input-wrap .input { padding-right: 40px; }
    .input-toggle {
      position: absolute; right: 0; top: 0; bottom: 0;
      width: 36px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-muted);
      transition: color var(--t);
    }
    .input-toggle:hover { color: var(--text); }
    .input-toggle:focus-visible { outline: none; color: var(--accent); }
    .input-toggle svg { width: 14px; height: 14px; }

    .msg { font-size: 13px; padding: var(--space-2) var(--space-3); border: 1px solid var(--border); display: none; }
    .msg.show { display: block; }
    .msg.error { color: var(--danger); border-color: var(--danger); background: var(--danger-soft); }
  </style>
</head>
<body>
  <button class="icon-btn theme-fab" onclick="toggleTheme()" aria-label="Toggle theme" data-theme-icon></button>

  <div class="pwd-card">
    <div class="brand">
      <div class="brand-mark"></div>
      <div class="brand-name">htmlhost</div>
    </div>

    <div class="pwd-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="11" width="16" height="10"/>
        <path d="M8 11V7a4 4 0 018 0v4"/>
      </svg>
    </div>

    <h1>Password protected</h1>
    <p class="sub">Enter the password to view <span class="paste-id">/p/<%= pasteId %></span></p>

    <form class="form" method="POST" action="/p/<%= pasteId %>" autocomplete="off">
      <div>
        <label class="label" for="password">Password</label>
        <div class="input-wrap">
          <input id="password" name="password" type="password" class="input" placeholder="Enter password" autofocus required>
          <button type="button" class="input-toggle" onclick="togglePassword()" aria-label="Show password" data-pwd-toggle>
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z"/>
              <circle cx="8" cy="8" r="2.5"/>
            </svg>
          </button>
        </div>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="msg error show"><%= error %></div>
      <% } %>
      <button type="submit" class="btn btn-primary btn-lg btn-block">Unlock</button>
    </form>
  </div>

  <%- include('partials/theme') %>

  <script>
    var eyeOpenSVG = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z"/><circle cx="8" cy="8" r="2.5"/></svg>';
    var eyeClosedSVG = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z"/><circle cx="8" cy="8" r="2.5"/><path d="M2 2l12 12"/></svg>';
    function togglePassword() {
      var input = document.getElementById('password');
      var btn = document.querySelector('[data-pwd-toggle]');
      var isHidden = input.type === 'password';
      input.type = isHidden ? 'text' : 'password';
      btn.innerHTML = isHidden ? eyeClosedSVG : eyeOpenSVG;
      btn.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
      input.focus();
      var v = input.value;
      input.value = '';
      input.value = v;
    }
  </script>
</body>
</html>
